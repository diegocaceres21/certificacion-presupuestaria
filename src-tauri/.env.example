# ============================================================
# Tauri client environment configuration
# ============================================================

# URL of the REST API server.
# REQUIRED for remote authentication and sync.
# Place this file as ".env" next to the installed executable,
# OR set the environment variable before building the MSI:
#   $env:API_URL = "http://192.168.1.100:3000"; npx tauri build
API_URL=http://localhost:3000

DATABASE_URL=mysql://user:password@host:3306/certificacion_presupuestaria
JWT_SECRET=your_super_secret_key_here_change_in_production

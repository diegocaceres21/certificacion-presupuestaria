{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "Certificacion Presupuestaria UCB",
  "version": "1.0.3",
  "identifier": "bo.edu.ucb.certificacion-presupuestaria",
  "build": {
    "frontendDist": "../dist/certificacion-presupuestaria/browser",
    "devUrl": "http://localhost:4200",
    "beforeDevCommand": "npm run start",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "windows": [
      {
        "title": "Certificación Presupuestaria — UCB San Pablo",
        "width": 1280,
        "height": 800,
        "minWidth": 1024,
        "minHeight": 700,
        "resizable": true,
        "fullscreen": false,
        "center": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["msi"],
    "createUpdaterArtifacts": "v1Compatible",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  },
  "plugins": {
    "updater": {
      "endpoints": [
        "https://github.com/diegocaceres21/certificacion-presupuestaria/releases/latest/download/latest.json"
      ],
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDM3ODVGRTAxMTNFOEU0MUYKUldRZjVPZ1RBZjZGTjRscWtHVHBPRnoyMFpZU1QrUEdzUFZ5WmM4QlFmWU1NSDhqb3JvOS80RkoK"
    }
  }
}
